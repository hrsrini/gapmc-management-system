# Copy to .env and fill in your values. Do not commit .env.
# Required for Drizzle and the API. After schema changes: npm run db:push
# Optional: npm run db:verify-schema (read-only column/trigger checks)
# Optional: npm run db:apply-land-immutable (land_records append-only triggers, after db:push)
# Optional: npm run db:apply-rent-invoice-tds (rent_invoices TDS columns, after db:push or run SQL manually)
# Optional: npm run db:apply-ioms-receipt-tds (ioms_receipts.tds_amount for M-05 PDF / 194-I line)
DATABASE_URL=postgresql://user:password@host:5432/database
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-in-production

# HR (M-01) Aadhaar fingerprint: prefer Admin → Config & PDF logo → "Aadhaar HMAC secret" (gapmc.system_config).
# Optional legacy bootstrap only if DB value is empty:
# AADHAAR_HMAC_SECRET=

# Optional: bind address (default 0.0.0.0 in server). Use 127.0.0.1 to listen on localhost only.
# HOST=127.0.0.1
#
# System defaults (market fee %, MSP, etc.) live in gapmc.system_config. Seed: npm run db:seed-ioms-m10
# Admin UI: /admin/config — read-only merged API for logged-in users: GET /api/system/config

# Production behind nginx / a load balancer: leave unset (default) so Express trusts first proxy hop
# for HTTPS cookies and client IP. Set to "false" only if Node is exposed directly with no reverse proxy.
# TRUST_PROXY=false

# Optional: hourly SLA reminder loop (M-03 Draft invoices, M-06 vouchers, M-09 Dak past deadline). Uses gapmc.sla_config + notify stub. Disable with:
# SLA_REMINDER=false
#
# Optional: M-03 rent invoice auto-generation (1st of month 00:01). Set to "true" to enable in-process cron.
# CRON_RENT_INVOICE=true
# CRON_M03_RENT_ARREARS=true
# Optional: M-02 auto-block expired trader licences (daily 01:05). Also: POST /api/cron/licence-expiry-auto-block
# CRON_LICENCE_EXPIRY=true
# Optional: M-02 expiry + overdue dues alert digest (daily 07:10). HTTP: POST /api/cron/m02-entity-alerts
# CRON_M02_ALERTS=true
# Optional: M-01 retirement date reminders (daily 07:15, stub notify). HTTP: POST /api/cron/hr-retirement-reminders
# CRON_HR_RETIREMENT=true
# Optional: M-07/M-08 fleet + AMC alert digest (daily 07:25, stub notify + audit). HTTP: POST /api/cron/operational-reminders-digest
# CRON_OPERATIONAL_DIGEST=true
# Optional: Secret for POST /api/cron/rent-invoice-generation (e.g. for external cron). If set, request must include header: x-cron-secret: <value>
# CRON_SECRET=your-cron-secret
# Optional: absolute site URL for QR codes on receipts (verify link). If unset, uses request Host.
# PUBLIC_APP_URL=https://your-domain.example
#
# Optional: receipt PDF logo if not uploaded in Admin → Config (PNG or JPEG)
# RECEIPT_PDF_LOGO_PATH=client/public/gaplmb-logo.png
# RECEIPT_PDF_LOGO_URL=https://example.org/logo.png
# Optional: full (default) vs body-only PDF when using pre-printed letterhead (SRS §8.6)
# RECEIPT_PDF_PRINT_MODE=full
# RECEIPT_PDF_PRINT_MODE=body-only
# Optional: printed signatory line on receipt PDF (text; not a cryptographic signature)
# RECEIPT_PDF_SIGNATORY_NAME=Authorised Officer
# Object storage: local `uploads/` (default) or S3-compatible bucket (Dak / voucher scans / receipt PDF logo).
# Local files default to <project>/uploads (resolved from server code location, not process.cwd).
# LOCAL_UPLOADS_DIR=uploads          # optional: absolute path, or relative to project root
# GAPMC_PROJECT_ROOT=                # optional: override project root if blob paths must resolve elsewhere
# OBJECT_STORAGE_DRIVER=local
# OBJECT_STORAGE_DRIVER=s3
# S3_BUCKET=your-bucket
# Optional: OBJECT_STORAGE_S3_BUCKET (alias of S3_BUCKET)
# S3_REGION=ap-south-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=gapmc/   # optional key prefix inside the bucket
# S3_ENDPOINT=http://127.0.0.1:9000   # MinIO / custom endpoint; set S3_FORCE_PATH_STYLE=true when needed
# S3_FORCE_PATH_STYLE=true
# Server-side encryption (SSE-S3): S3_SERVER_SIDE_ENCRYPTION=AES256
# OBJECT_STORAGE_SSE=AES256
# Optional: audit_log user_id for cron/system jobs (defaults to literal "system", no users row required).
# Set to a real users.id if compliance requires a FK-capable actor.
# AUDIT_SYSTEM_USER_ID=system
#
# Optional: disable anonymous receipt QR + verify API (default: enabled)
# PUBLIC_RECEIPT_VERIFY_ENABLED=false
#
# Payment gateway callback: POST /api/ioms/receipts/payments/callback is public (no session). Protect production with HMAC:
# PAYMENT_WEBHOOK_HMAC_SECRET=shared-secret-with-gateway
# Optional: reject startup of callback policy unless secret is set (set true in production when gateway is live)
# PAYMENT_WEBHOOK_REQUIRE_HMAC=true
# Signature: lowercase hex SHA256-HMAC of raw JSON body; header X-Payment-Signature or X-Signature-Hmac-Sha256
#
# UAT only: allow POST .../payments/dev-simulate-callback (session auth, no HMAC) in production staging:
# PAYMENT_DEV_CALLBACK_ENABLED=true
# Optional: GSTIN for GSTR-1 export (included in JSON when set)
# GSTIN=99AAAAA0000A1Z5
#
# Notifications (SLA / cron digests): console always; optional outbound channels:
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/notify   # POST JSON payload + subject/text
# NOTIFY_SMS_WEBHOOK_URL=https://sms-gateway.example/notify  # optional; same JSON shape + channel: "sms" (client/NIC gateway)
# NOTIFY_EMAIL_TO=ops@example.com                      # when SMTP is configured
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# When SMTP_* is set, M-10 employee login provisioning also emails the employee address (US-M10-001).
#
# Payment gateway adapter for future integrations (Phase 1: cash/cheque in-app; gateway pending):
# PAYMENT_GATEWAY_MODE=stub   # stub | none
# Optional: allow UPI/Online/etc. on POST /api/ioms/receipts (default: only Cash, Cheque, DD)
# RECEIPT_ALLOW_ANY_PAYMENT_MODE=true
# Optional: enable POST /api/ioms/receipts/:id/payments/initiate (default: disabled in Phase 1)
# PAYMENT_GATEWAY_INIT_ENABLED=true
#
# Optional: M-08 AMC renewal digest (daily 07:35). HTTP: POST /api/cron/amc-renewal-digest
# CRON_AMC_DIGEST=true
# Optional: M-08 auto-create monthly AMC bill rows (daily 02:20 UTC; Monthly period_type only). HTTP: POST /api/cron/amc-monthly-bills
# Also requires Admin → Config `amc_monthly_auto_generate=true` (default false per Excel / SRS alignment).
# CRON_AMC_MONTHLY_BILLS=true
# Optional: weekly data retention snapshot (Sundays 04:00 UTC): counts rows past policy ages in system_config; writes audit_log; no deletes. HTTP: POST /api/cron/data-retention-audit
# CRON_DATA_RETENTION_AUDIT=true
# ----- Playwright (npm run test:pw*) -----
# Base URL for browser + API tests (default http://127.0.0.1:5000). Must match the dev server port.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5000
# Skip auto-start of `npm run dev` (use when you already have the server running):
# PW_NO_WEBSERVER=1
# Admin credentials for login tests (optional; otherwise tries GapmcAdmin@2026! then Apmc@2026):
# PW_ADMIN_EMAIL=admin@gapmc.local
# PW_ADMIN_PASSWORD=GapmcAdmin@2026!
#
# Optional: one-shot SLA / Dak escalation tick (same as hourly loop). HTTP: POST /api/cron/sla-reminder-tick
