# Copy to .env and fill in your values. Do not commit .env.
DATABASE_URL=postgresql://user:password@host:5432/database
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-in-production

# Optional: M-03 rent invoice auto-generation (1st of month 00:01). Set to "true" to enable in-process cron.
# CRON_RENT_INVOICE=true
# Optional: Secret for POST /api/cron/rent-invoice-generation (e.g. for external cron). If set, request must include header: x-cron-secret: <value>
# CRON_SECRET=your-cron-secret
# Optional: GSTIN for GSTR-1 export (included in JSON when set)
# GSTIN=99AAAAA0000A1Z5
